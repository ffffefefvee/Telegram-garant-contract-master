# Copy to mini-app/.env for local dev (never commit .env with secrets).

# Backend API (user-service)
VITE_API_URL=http://localhost:3001/api

# Browser / Playwright E2E without Telegram client (requires AUTH_DEV_MODE=true on backend)
VITE_TG_MOCK=true
# Same numeric ID as TELEGRAM_CHAT_ID in repo root .env
VITE_MOCK_TG_USER_ID=7124952069
# dark | light — default UI style for local dev (ZELENKA = dark)
VITE_MOCK_TG_COLOR_SCHEME=dark
