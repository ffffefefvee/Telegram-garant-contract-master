{
  "extends": "solhint:recommended",
  "rules": {
    "compiler-version": [
      "error",
      "^0.8.0"
    ],
    "func-visibility": [
      "error",
      {
        "ignoreConstructors": true
      }
    ],
    "immutable-vars-naming": "off",
    "no-global-import": "off",
    "max-states-count": [
      "warn",
      20
    ]
  }
}