# Copy this file to .env and fill real values. Never commit .env.
# All values below are PLACEHOLDERS — they must be replaced.

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=garant_user
DB_PASSWORD=replace_me_with_strong_password
DB_NAME=garant_db
DB_USE_SQLITE=false

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace_me_with_strong_password

# Telegram Bot — get token from @BotFather
TELEGRAM_BOT_TOKEN=replace_me_with_token_from_botfather
# Numeric Telegram user ID for bot E2E tests (skill telegram-bot-tester).
# Must match ALLOWED_USER_ID in ~/.cursor/mcp.json (mcpServers.telegram.env).
TELEGRAM_CHAT_ID=replace_me_with_your_telegram_user_id
# Dev-only: inject synthetic Telegram updates (POST /api/internal/telegram/test/*)
TELEGRAM_TEST_INJECT_ENABLED=false
TELEGRAM_TEST_INJECT_SECRET=replace_me_openssl_rand_hex_32
# If api.telegram.org is blocked, set a local proxy (Clash/V2Ray often use 7890):
# HTTPS_PROXY=http://host.docker.internal:7890
# Optional: self-hosted Telegram Bot API server
# TELEGRAM_API_ROOT=http://host.docker.internal:8081
TELEGRAM_API_ID=replace_me
TELEGRAM_API_HASH=replace_me
# Bot username + Mini App short_name — used to build deeplink buttons in
# notifications (https://t.me/<username>/<slug>?startapp=<context>).
# If either is empty, notifications fall back to text-only messages.
TELEGRAM_BOT_USERNAME=
TELEGRAM_MINIAPP_SLUG=app
# Support @username shown in bot (without @)
TELEGRAM_SUPPORT_USERNAME=

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=replace_me_with_random_64_hex_chars

# Application
NODE_ENV=development
USER_SERVICE_PORT=3001
# Comma-separated origin allow-list. With "*" credentialed requests are
# disabled (browsers reject wildcard + credentials). Set explicit origins in
# production, e.g. https://app.yourdomain.com
CORS_ORIGIN=*
# TypeORM schema sync. Defaults: ON in dev, OFF in production (use migrations
# + DB_MIGRATIONS_RUN=true instead). Only set to true in production knowingly.
# DB_SYNCHRONIZE=false
# DB_MIGRATIONS_RUN=true
# Required for mini-app VITE_TG_MOCK → POST /api/auth/dev-login (Playwright E2E)
AUTH_DEV_MODE=false
# Public HTTPS URL of this backend — used by Cryptomus as webhook callback base.
# Example: https://api.yourdomain.com
# Must be reachable from the internet; ngrok or similar for local dev.
BACKEND_URL=https://replace_me_with_your_backend_url

# i18n
I18N_HOT_RELOAD=true

# Cryptomus (Phase 1 — payment integration)
CRYPTOMUS_MERCHANT_ID=replace_me
CRYPTOMUS_API_KEY=replace_me
# Webhook HMAC uses CRYPTOMUS_API_KEY (see CryptomusWebhookController)
CRYPTOMUS_SANDBOX=true
# Comma-separated source IPs allowed to call the webhook endpoint. Cryptomus
# sends from 91.227.144.54 (see their docs). Leave EMPTY to disable the check
# (needed for local/sandbox testing via ngrok, where the source IP differs).
# Set in production for replay/forgery protection on top of the HMAC signature.
CRYPTOMUS_WEBHOOK_IP_ALLOWLIST=
# Public hosted HTTPS URL of the mini-app (return after Cryptomus payment).
# Do not set this to t.me/... . Telegram deeplinks are built separately from
# TELEGRAM_BOT_USERNAME + TELEGRAM_MINIAPP_SLUG.
# Also used as success redirect in Cryptomus invoice; does NOT affect webhook HMAC
# (webhook signature uses CRYPTOMUS_API_KEY — see CryptomusWebhookController).
MINI_APP_URL=https://replace_me_with_mini_app_url

# Blockchain (Polygon mainnet for prod, Amoy for testnet)
BLOCKCHAIN_RPC_URL=https://polygon-amoy-bor-rpc.publicnode.com
BLOCKCHAIN_CHAIN_ID=80002
# The relay/admin hot-wallet. Forwards Cryptomus payments → escrow clones,
# calls notifyFunded(), assigns arbitrators. Holds platform fees ephemerally.
# DO NOT reuse for anything else; rotate if compromised.
BLOCKCHAIN_PRIVATE_KEY=replace_me_with_relay_wallet_private_key
# Output of `npx hardhat run scripts/deploy.ts` from the contracts/ package
ESCROW_FACTORY_ADDRESS=
PLATFORM_TREASURY_ADDRESS=
ARBITRATOR_REGISTRY_ADDRESS=
# Polygon mainnet USDT: 0xc2132D05D31c914a87C6611C10748AEb04B58e8F
USDT_CONTRACT_ADDRESS=
# Alert when on-chain treasury reserve (6-decimal USDT raw units) drops below this
TREASURY_LOW_RESERVE_RAW=1000000000

# TON rail (Stage 2 — USDT-TON via @wallet / any TON wallet)
# Platform TON wallet that receives USDT-TON deposits (friendly EQ…/UQ… form).
# Leave empty to disable the TON payment method entirely.
TON_WALLET_ADDRESS=
# Jetton master of accepted USDT (default: Tether USDT on TON mainnet)
TON_USDT_JETTON=EQCxE6mUtQJKFnGfaROTKOt1lZbDiiX1kCixRv7Nw2Id_sDs
# tonapi.io access (key optional — raises rate limits)
TONAPI_BASE_URL=https://tonapi.io
TONAPI_KEY=
# Auto-hide the TON rail from the mini-app when the relay's Polygon USDT
# float drops below this amount (user decision: start with $500–2000)
TON_MIN_FLOAT_USDT=500
# Warn-level float alert threshold (default: 2x TON_MIN_FLOAT_USDT)
TON_FLOAT_WARN_USDT=1000
# Toncoin rail rate lock: safety buffer on the quoted TON amount (percent)
# and how long the locked rate stays valid (minutes)
TON_RATE_BUFFER_PCT=1
TON_RATE_LOCK_TTL_MINUTES=30
# Warn when the platform TON wallet accumulates this much value (USD) —
# time to rebalance TON→Polygon (default: 2x TON_MIN_FLOAT_USDT; 0 disables)
TON_REBALANCE_ALERT_USD=1000
# Scanner for incoming TON deposits no payment claims (missing/typo'd memo)
TON_UNMATCHED_SCANNER_ENABLED=true
TON_UNMATCHED_LOOKBACK_HOURS=24

# Ops alerting: Telegram chat id that receives ERROR/CRITICAL system alerts
# (your own chat with the bot; leave empty to disable pushes)
OPS_ALERT_CHAT_ID=

# Notifications
DEAL_REMINDERS_ENABLED=true
NOTIFICATION_WORKER_ENABLED=true

# API rate limiting (global, per client IP, in-memory).
# Defaults: 120 requests per 60s window. Auth endpoints are additionally
# capped at 30/min per IP in code. Raise THROTTLE_LIMIT for load tests.
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
