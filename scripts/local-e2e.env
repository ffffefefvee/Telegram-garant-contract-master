# Env for scripts/local-e2e.sh — DO NOT use these values in any other context.
# Sourced by the e2e runner. Spins up a throwaway Postgres in Docker, leaves
# every external integration in stub mode (blockchain, cryptomus, telegram).

NODE_ENV=development

# Postgres in Docker (created/destroyed by local-e2e.sh on a non-default port
# so it doesn't collide with `docker-compose up`).
DB_USE_SQLITE=false
DB_HOST=127.0.0.1
DB_PORT=5499
DB_USERNAME=e2e
DB_PASSWORD=e2e
DB_NAME=e2e

# JWT signing secret. Required by dev-login. Never reuse in any other context.
JWT_SECRET=local-e2e-jwt-secret-not-real-do-not-reuse-keep-32b

# TELEGRAM_BOT_TOKEN intentionally empty so the Telegraf bot never tries to
# poll Telegram. AuthService /auth/telegram returns 503 in this state, but
# /auth/dev-login bypasses it (and it's all we need for the smoke).
TELEGRAM_BOT_TOKEN=

# Dev-login backdoor — only works when AUTH_DEV_MODE=true && NODE_ENV != production.
AUTH_DEV_MODE=true

# Notifications + telegram-bot disabled — we only care about backend wiring.
NOTIFICATIONS_ENABLED=false

# Blockchain stub mode: BlockchainProvider treats unset RPC as "not ready"
# and TreasuryClient/Erc20Client return zeroes. Treasury endpoint reflects
# this with ready=false.
BLOCKCHAIN_RPC_URL=
BLOCKCHAIN_PRIVATE_KEY=
ESCROW_FACTORY_ADDRESS=
PLATFORM_TREASURY_ADDRESS=
ARBITRATOR_REGISTRY_ADDRESS=
USDT_CONTRACT_ADDRESS=

# Redis stub: ioredis lazy-connects when host points at nothing — we never
# actually issue commands during the smoke, only the connection wrapper.
REDIS_HOST=127.0.0.1
REDIS_PORT=6399
REDIS_PASSWORD=stub

USER_SERVICE_PORT=3099
CORS_ORIGIN=*
I18N_HOT_RELOAD=false
